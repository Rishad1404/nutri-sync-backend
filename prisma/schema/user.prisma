enum Role {
    ADMIN
    USER
}

enum UserStatus {
    ACTIVE
    BLOCKED
    DELETED
}

model User {
    id            String     @id @default(cuid())
    name          String
    email         String
    emailVerified Boolean    @default(false)
    role          Role       @default(USER)
    status        UserStatus @default(ACTIVE)

    dietaryPreferences String[] @default([])
    allergies          String[] @default([])
    goals              String?
    calorieTarget      Int      @default(2000)
    
    // Health Profile
    age           Int?
    gender        String?
    weight        Float?
    height        Float?
    activityLevel String?

    recipes      Recipe[]
    mealPlans    MealPlan[]
    favorites    Favorite[]
    chatHistory  ChatHistory[]
    nutritionLog UserNutritionLog[]

    needPasswordChange Boolean   @default(false)
    isDeleted          Boolean   @default(false)
    deletedAt          DateTime?
    image              String?
    createdAt          DateTime  @default(now())
    updatedAt          DateTime  @updatedAt
    sessions           Session[]
    accounts           Account[]

    @@unique([email])
    @@map("user")
}

model Favorite {
    id       String @id @default(cuid())
    userId   String
    recipeId String

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@unique([userId, recipeId])
    @@index([userId], name: "idx_favorite_userId")
    @@index([recipeId], name: "idx_favorite_recipeId")
    @@map("favorites")
}

model ChatHistory {
    id     String @id @default(cuid())
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    message       String @db.Text
    response      String @db.Text
    recipeContext Json?

    createdAt DateTime @default(now())

    @@index([userId], name: "idx_chat_history_userId")
    @@index([createdAt], name: "idx_chat_history_createdAt")
    @@map("chatHistory")
}
